{
	"name": "danielboring/webmastery-site-toolkit-for-mcp",
	"description": "WordPress plugin that adds MCP-powered site management abilities.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.1",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1"
	},
	"scripts": {
		"diff-check": "git diff --check",
		"e2e": "bash scripts/e2e-test.sh",
		"phpcs": "phpcs --standard=phpcs.xml.dist",
		"phpcbf": "phpcbf --standard=phpcs.xml.dist",
		"qa": [
			"@phpcs",
			"@validate:e2e-manifest",
			"@diff-check"
		],
		"validate:e2e-manifest": "php scripts/validate-e2e-manifest.php"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	}
}
