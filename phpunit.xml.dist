<?xml version="1.0"?>
<phpunit
	bootstrap="tests/unit/bootstrap.php"
	colors="true"
	convertErrorsToExceptions="true"
	convertNoticesToExceptions="true"
	convertWarningsToExceptions="true"
>
	<testsuites>
		<testsuite name="Unit">
			<directory>tests/unit</directory>
		</testsuite>
	</testsuites>
</phpunit>
